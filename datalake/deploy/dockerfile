FROM python:3.11-slim

WORKDIR /app

# Персистентный home Dagster: совпадает с точкой монтирования volume
# dagster_storage в docker-compose.yml. Без него dagster dev пишет в
# временный /app/.tmp_dagster_home_* и теряет историю ранов при рестарте.
ENV DAGSTER_HOME=/app/.dagster_home
RUN mkdir -p /app/.dagster_home

# Исходники + pyproject копируем вместе, затем editable-install:
# ставит пакет `datalake` (import datalake.* работает) и все зависимости из pyproject.
COPY datalake/deploy/pyproject.toml ./pyproject.toml
COPY datalake/__init__.py datalake/paths.py datalake/definitions.py ./datalake/
COPY datalake/connectors ./datalake/connectors
COPY datalake/pipelines ./datalake/pipelines
COPY datalake/jobs ./datalake/jobs
RUN pip install --no-cache-dir -e .

EXPOSE 3000

# Запуск по модулю (раскладка пакета), а не по файлу.
CMD ["dagster", "dev", "-m", "datalake.definitions", "-h", "0.0.0.0", "-p", "3000"]
